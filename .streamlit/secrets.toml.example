# Copy these values into Streamlit Community Cloud > App settings > Secrets.
# Use the Supabase PostgreSQL pooler URI, not the Project URL or anon API key.
SUPABASE_DB_URL = "postgresql://postgres.PROJECT_REF:PASSWORD@POOLER_HOST:5432/postgres?sslmode=require"

# Separate physical LOGIN used only for AI SELECT queries. Use a long random value.
# The app derives the matching pooler URL and provisions talktodata_reader securely.
SUPABASE_READER_PASSWORD = "replace-with-a-long-random-reader-password"

# Leave false for public access. Change to true later to restore the login screen.
AUTH_REQUIRED = false

# Keep public registration disabled in production. Enable only while creating an account.
ALLOW_SIGNUP = false

# Optional: use a separate PostgreSQL role/URL for login and saved-table metadata.
# If omitted, SUPABASE_DB_URL is used for both data and metadata.
# SUPABASE_META_DB_URL = "postgresql://metadata_role:PASSWORD@POOLER_HOST:5432/postgres?sslmode=require"

OPENAI_API_KEY = "sk-..."
OPENAI_MODEL = "gpt-5.2"
